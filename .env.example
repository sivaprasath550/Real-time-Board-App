# Copy this file to .env and fill in your values

# Database (SQLite for dev)
DATABASE_URL="file:./dev.db"
# Production PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/board?sslmode=require"

AUTH_COOKIE_NAME="board_session"
NEXTAUTH_URL="http://localhost:3000"

GEMINI_API_KEY="your-gemini-api-key-here"

# Email - leave empty to use Ethereal sandbox (check terminal for preview URL)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
